+    private PdfPTable buildMainTable(
+            List<User> students,
+            List<Course> courses,
+            Map<Integer, List<Session>> sessionsByCourse,
+            Map<Integer, Map<Integer, AttendanceRecord>> attendanceMap)
+            throws DocumentException {
+
+        int C = courses.size();
+        // colonnes : Nв”¬в–‘ | NOMS | GENRE | MATRICULE | 5*C (TH|HJ|TA|DEC|MALUS) | THS | THJ
+        int totalCols = 4 + 5 * C + 2;
+
+        PdfPTable table = new PdfPTable(totalCols);
+        table.setWidthPercentage(100);
+        table.setKeepTogether(false);
+
+        // О“Г¶Г‡О“Г¶Г‡ Largeurs relatives О“Г¶Г‡О“Г¶Г‡
+        float nW   = 2.5f;
+        float nmW  = 14f;
+        float geW  = 4.5f;
+        float maW  = 7f;
+        float cW   = 3.2f;  // 5 sous-colonnes par cours
+        float tsW  = 4f;
+        float tjW  = 4f;
+
+        float[] widths = new float[totalCols];
+        widths[0] = nW;
+        widths[1] = nmW;
+        widths[2] = geW;
+        widths[3] = maW;
+        for (int i = 0; i < C * 5; i++) widths[4 + i] = cW;
+        widths[totalCols - 2] = tsW;
+        widths[totalCols - 1] = tjW;
+        table.setWidths(widths);
+
+        // О“Г¶Г‡О“Г¶Г‡ Ligne 1 des en-tв”њВ¬tes (noms des cours + THF) О“Г¶Г‡О“Г¶Г‡
+        addCourseHeaderRow1(table, courses, C);
+
+        // О“Г¶Г‡О“Г¶Г‡ Ligne 2 des en-tв”њВ¬tes (TH | HJ | TA | DEC | MALUS) О“Г¶Г‡О“Г¶Г‡
+        addCourseHeaderRow2(table, C);
+
+        // О“Г¶Г‡О“Г¶Г‡ Lignes de donnв”њвЊђes О“Г¶Г‡О“Г¶Г‡
+        int rowNum = 0;
+        for (User student : students) {
+            rowNum++;
+            addStudentRow(table, rowNum, student, courses,
+                    sessionsByCourse, attendanceMap, rowNum % 2 == 0);
+        }
+
+        return table;
+    }
